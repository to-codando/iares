{

  "compilerOptions": {
    "strict": true,
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",

    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "lib",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames":true,
    "skipLibCheck": true,
    "lib": ["es2022", "dom"],
  },
  "include": ["src/**/*", "index.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
